        <mxCell id="legend" value="&lt;b&gt;Legend:&lt;/b&gt;  &lt;font color='#27d4ff'&gt;cyan = The Net&lt;/font&gt;   &lt;font color='#55ff99'&gt;green = Meatspace&lt;/font&gt;   &lt;font color='#ffb000'&gt;amber = frontier / safehouse&lt;/font&gt;   &lt;font color='#ff4f4f'&gt;red = endgame boss&lt;/font&gt;&lt;br&gt;Each band = 4 rooms: Approach › Field › Den › Boss.  Themes / monsters = TBD." style="text;html=1;fontColor=#5a6678;fontSize=13;fontFamily=Menlo;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="1190" width="1020" height="60" as="geometry"/></mxCell>
        <mxCell id="zone1" value="&lt;b&gt;ZONE 1 — SHARED START (L1-10)&lt;/b&gt;&lt;br&gt;Re-Clone Bay · Neon Alley (hub, safe) · Chrome Rose (vendor)&lt;br&gt;The Strip · Night Market (vendor+medic) · Corporate Plaza&lt;br&gt;jack-in @ Data Port → The Net → Sentinel Lattice → Deep Net" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#11151f;fontColor=#d7e0ee;fontFamily=Menlo;fontSize=14;strokeWidth=2;align=center;verticalAlign=middle;strokeColor=#27d4ff;fontSize=15;" vertex="1" parent="1"><mxGeometry x="150" y="70" width="760" height="140" as="geometry"/></mxCell>
